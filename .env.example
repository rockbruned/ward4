# Public site URL (canonical links, Open Graph, QR codes)
NEXT_PUBLIC_SITE_URL=https://donrockbrune.com

# Campaign contact email (also default for chat notifications)
CONTACT_EMAIL=Oshawa@INsportify.com

# Google Analytics (optional)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Chat email (Resend) ---
# Required for "Talk to Don" email forwarding. Get keys at https://resend.com
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM_EMAIL=Don Rockbrune <notify@yourdomain.com>

# Optional: override inbox for chat notifications (defaults to CONTACT_EMAIL)
# CHAT_NOTIFY_EMAIL=Oshawa@INsportify.com

# --- Chat database (Railway Postgres) ---
# Optional: stores chat messages for campaign follow-up. Chat works without this.
# DATABASE_URL=postgresql://postgres:password@hostname.railway.app:5432/railway
